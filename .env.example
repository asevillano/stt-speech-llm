# --- Speech service ---
SPEECH_REGION=westeurope
# Format: /subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<resource>
SPEECH_RESOURCE_ID=/subscriptions/<sub>/resourceGroups/<rg>/providers/Microsoft.CognitiveServices/accounts/<resource>

# --- Azure OpenAI: intent detection (required) ---
AZURE_OPENAI_INTENT_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_INTENT_MODEL=gpt-4.1-mini

# --- Azure OpenAI: summary (optional, defaults to the intent values) ---
# Set these only if summary uses a different endpoint/model.
# When they differ from intent, intent and summary run as two parallel calls.
# AZURE_OPENAI_SUMMARY_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_SUMMARY_MODEL=gpt-4.1-mini

# --- Open models via Azure AI Inference (optional) ---
# When True, models are consumed through the chat completions API instead of
# Azure OpenAI (Responses API). Requires: pip install azure-ai-inference
SERVERLESS_MODELS=False

# API keys used ONLY when SERVERLESS_MODELS=True (otherwise Entra ID is used).
# AZURE_OPENAI_INTENT_KEY=<key>
# AZURE_OPENAI_SUMMARY_KEY=<key>
